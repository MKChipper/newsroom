# Frontend points at the Convex deployment.
# Local development writes this into .env.local when you run npx convex dev.
VITE_CONVEX_URL=

# Convex deployment selected by local CLI/dev tooling.
CONVEX_DEPLOYMENT=

# Vercel/CI only. Generate this from the Convex production deployment settings.
CONVEX_DEPLOY_KEY=

# Vercel production basic-auth gate, formatted as username:password.
NEWSROOM_BASIC_AUTH=

# Local staff only. Keep these out of the browser/Vercel frontend.
FAL_KEY=
DE_NEWSROOM_BOT_TOKEN=
